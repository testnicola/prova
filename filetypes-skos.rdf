   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/PPTX"
                 at:deprecated="false">
      <euvoc:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1300</euvoc:order>
