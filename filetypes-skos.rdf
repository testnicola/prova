   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/PPSX"
                 at:deprecated="false">
      <euvoc:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1500</euvoc:order>
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/vnd.openxmlformats-officedocument.presentationml.slideshow</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/vnd.openxmlformats-officedocument.presentationml.slideshow</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MANIFT">ppsx</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.ppsx</skos:notation>
      <skos:prefLabel xml:lang="en">PowerPoint PPSX</skos:prefLabel>
      <skos:prefLabel xml:lang="et">PowerPoint PPSX</skos:prefLabel>
      <skos:definition xml:lang="en">PPSX – PowerPoint 2007 XML slide show – is an XML filename extension of Microsoft PowerPoint presentation program. PowerPoint was originally designed to provide visuals for group presentations within business organizations, but has come to be very widely used in many other communication situations, both in business and beyond.</skos:definition>
      <dc:identifier>PPSX</dc:identifier>
      <atold:op-code>PPSX</atold:op-code>
      <at:op-code>PPSX</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>PPSX</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.ppsx</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-textual-cellar</dc:source>
            <at:legacy-code>false</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>manifestation-type-cellar</dc:source>
            <at:legacy-code>ppsx</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/vnd.openxmlformats-officedocument.presentationml.slideshow</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>priority-weight-cellar</dc:source>
            <at:legacy-code>1500</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">PowerPoint Open XML Slide Show</skos:altLabel>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} * PPS et PPSX version 2007 et ultérieures: permet de visualiser en plein écran la présentation créée. Elle pourra être visualisée par les gens qui ont PowerPoint ou qui ne l’ont pas! En fait, il est possible de télécharger une visionneuse gratuite qui vous permettra de regarder la présentation en format PPS ou PPSX sans avoir le logiciel. * Modified label into "Office Open XML Slideshow" from "Microsoft PowerPoint 2007 Slideshow" to be consistent with PPTX, XLSX and DOCX</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/ZIP"
                 at:deprecated="false">
