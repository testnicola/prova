      <skos:prefLabel xml:lang="et">XHTML</skos:prefLabel>
      <skos:prefLabel xml:lang="en">XHTML</skos:prefLabel>
      <skos:definition xml:lang="en">XHTML is a family of current and future document types and modules that reproduce, subset and extend HTML 4. XHTML family document types are XML based.</skos:definition>
      <dc:identifier>XHTML</dc:identifier>
      <atold:op-code>XHTML</atold:op-code>
