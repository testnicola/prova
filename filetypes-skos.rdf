   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/GEOTIFF"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">image/tiff</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.tiff</skos:notation>
      <skos:prefLabel xml:lang="et">GeoTIFF</skos:prefLabel>
      <skos:prefLabel xml:lang="en">GeoTIFF</skos:prefLabel>
      <skos:definition xml:lang="en">GeoTIFF is a public domain metadata standard which allows georeferencing information to be embedded within a TIFF file. The potential additional information includes map projection, coordinate systems, ellipsoids, datums, and everything else necessary to establish the exact spatial reference for the file.</skos:definition>
      <dc:identifier>GEOTIFF</dc:identifier>
      <atold:op-code>GEOTIFF</atold:op-code>
      <at:op-code>GEOTIFF</at:op-code>
      <at:start.use>2019-09-14</at:start.use>
      <at:authority-code>GEOTIFF</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.tiff</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">OGC GeoTIFF</skos:altLabel>
   </skos:Concept>
