      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>text/sgml;type=fmx2</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Formalized Exchange of Electronic Publications (Formex), version 2</skos:altLabel>
      <skos:historyNote xml:lang="en">{comment_about_IANA} No file extension on IANA website</skos:historyNote>
      <skos:historyNote xml:lang="en">Formex 2 1.1.1989 - 31.3.1999: Structure language created and maintained by the Publications Office, on the basis of SGML. The character encoding is organised according to ISO 2022 and ISO 8856-*.</skos:historyNote>
      <at:end.use>1999-03-31</at:end.use>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/PDF"
                 at:deprecated="false">
      <euvoc:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2300</euvoc:order>
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/pdf</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.pdf</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MANIFT">pdf</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/pdf;type=pdf1x</skos:notation>
      <skos:prefLabel xml:lang="en">PDF</skos:prefLabel>
      <skos:prefLabel xml:lang="et">PDF</skos:prefLabel>
      <skos:definition xml:lang="en">PDF – Portable Document Format – is a file format developed to present documents, including text formatting and images, in a manner independent of application software, hardware and operating systems. Based on the PostScript language, each PDF file encapsulates a complete description of a fixed-layout flat document, including the text, fonts, vector graphics, raster images and other information needed to display it. PDF was standardized as an open format and does not require any royalties for its implementation.</skos:definition>
      <dc:identifier>PDF</dc:identifier>
      <atold:op-code>PDF</atold:op-code>
      <at:op-code>PDF</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>PDF</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-textual-cellar</dc:source>
            <at:legacy-code>false</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/pdf;type=pdf1x</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>priority-weight-cellar</dc:source>
            <at:legacy-code>2300</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>manifestation-type-cellar</dc:source>
            <at:legacy-code>pdf</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.pdf</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Portable Document Format</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:historyNote xml:lang="en">ISO 32000-1</skos:historyNote>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} "IANA MIME Media Type" application/pdf corresponds always in the Cellar to application/pdf;type=pdf1x</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/MP3"
                 at:deprecated="false">
      <euvoc:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">110</euvoc:order>
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
