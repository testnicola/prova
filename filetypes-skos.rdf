      <skos:prefLabel xml:lang="en">RDF TriG</skos:prefLabel>
      <skos:prefLabel xml:lang="et">RDF TriG</skos:prefLabel>
      <skos:definition xml:lang="en">TriG allows an RDF dataset to be completely written in a compact and natural text form, with abbreviations for common usage patterns and datatypes. TriG is an extension of the Turtle format.</skos:definition>
      <dc:identifier>RDF_TRIG</dc:identifier>
      <atold:op-code>RDF_TRIG</atold:op-code>
      <at:op-code>RDF_TRIG</at:op-code>
