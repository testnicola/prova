      <skos:prefLabel xml:lang="en">ZIP</skos:prefLabel>
      <skos:prefLabel xml:lang="et">ZIP</skos:prefLabel>
      <skos:definition xml:lang="en">ZIP is an archive file format that supports lossless data compression. A ZIP file may contain one or more files or directories that may have been compressed.</skos:definition>
      <dc:identifier>ZIP</dc:identifier>
      <atold:op-code>ZIP</atold:op-code>
