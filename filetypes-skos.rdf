      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-indesign</skos:notation>
      <skos:prefLabel xml:lang="et">INDD</skos:prefLabel>
      <skos:prefLabel xml:lang="en">INDD</skos:prefLabel>
      <skos:definition xml:lang="en">INDD is a file format for a page layout file used by Adobe InDesign. InDesign is a desktop publishing software application.</skos:definition>
      <dc:identifier>INDD</dc:identifier>
      <atold:op-code>INDD</atold:op-code>
      <at:op-code>INDD</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>INDD</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.indd</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Adobe InDesign Document</skos:altLabel>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} Professional page layout project created with Adobe InDesign; includes page formatting information, page content, linked files, styles, and swatches; used for creating and formatting books, magazines, newspapers, flyers, brochures, etc. InDesign documents can also be opened with InCopy, Adobe's professional writing program. They may be imported into QuarkXpress using the ID2Q plugin.</skos:historyNote>
   </skos:Concept>
