   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/Z"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-compress</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.Z</skos:notation>
      <skos:prefLabel xml:lang="en">Z</skos:prefLabel>
      <skos:prefLabel xml:lang="et">Z</skos:prefLabel>
      <skos:definition xml:lang="en">Compressed file produced by Unix shell compression program based on the LZW (Lempel-Ziv-Welch) compression algorithm.</skos:definition>
      <dc:identifier>Z</dc:identifier>
      <atold:op-code>Z</atold:op-code>
      <at:op-code>Z</at:op-code>
      <at:start.use>1985-02-01</at:start.use>
      <at:authority-code>Z</at:authority-code>
      <at:op-mapped-code>
