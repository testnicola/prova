      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.ovf</skos:notation>
      <skos:prefLabel xml:lang="et">OVF</skos:prefLabel>
      <skos:prefLabel xml:lang="en">OVF</skos:prefLabel>
      <skos:definition xml:lang="en">OVF – Open Virtualization Format – is an open standard for packaging and distributing virtual appliances or more generally software to be run in virtual machines.</skos:definition>
      <dc:identifier>OVF</dc:identifier>
      <atold:op-code>OVF</atold:op-code>
