         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Notation3</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/RDF_TRIX"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.trix</skos:notation>
      <skos:prefLabel xml:lang="et">RDF TriX</skos:prefLabel>
      <skos:prefLabel xml:lang="en">RDF TriX</skos:prefLabel>
      <skos:definition xml:lang="en">TriX (Triples in XML) is a serialization format for RDF (Resource Description Framework) graphs. It is an XML format for serializing Named Graphs and RDF Datasets which offers a compact and readable alternative to the XML-based RDF/XML syntax.</skos:definition>
      <dc:identifier>RDF_TRIX</dc:identifier>
      <atold:op-code>RDF_TRIX</atold:op-code>
      <at:op-code>RDF_TRIX</at:op-code>
      <at:start.use>2004-05-13</at:start.use>
      <at:authority-code>RDF_TRIX</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.xml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.trix</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Triples in XML</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/SVG"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.svgz</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.svg</skos:notation>
