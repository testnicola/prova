      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.appxbundle</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Microsoft AppX application package</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/ARROW_STREAM"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.arrows</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/vnd.apache.arrow.stream</skos:notation>
      <skos:prefLabel xml:lang="en">Arrow stream</skos:prefLabel>
      <skos:prefLabel xml:lang="et">Arrow stream</skos:prefLabel>
      <skos:definition xml:lang="en">Apache columnar format that includes a language-agnostic in-memory data structure specification, metadata serialisation, and a protocol for serialisation and generic data transport; streaming format is used for sending an arbitrary length sequence of record batches</skos:definition>
      <dc:identifier>ARROW_STREAM</dc:identifier>
