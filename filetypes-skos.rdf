         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.tar.gz</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Darwin Core Archive</skos:altLabel>
   </skos:Concept>
