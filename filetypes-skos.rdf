      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-textual-cellar</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.css</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>manifestation-type-cellar</dc:source>
            <at:legacy-code>css</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>text/css</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>priority-weight-cellar</dc:source>
            <at:legacy-code>70</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Cascading Style Sheet</skos:altLabel>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} Cascading Style Sheet CSS file used to format the contents of a Web page; contains customized, global properties for how to display HTML elements; can define the size, color, font, line spacing, indentation, borders, and location of HTML elements.</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/SGML"
                 at:deprecated="false">
      <euvoc:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1000</euvoc:order>
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">text/sgml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.sgml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.sgm</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MANIFT">sgml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">text/sgml</skos:notation>
      <skos:prefLabel xml:lang="et">SGML</skos:prefLabel>
      <skos:prefLabel xml:lang="en">SGML</skos:prefLabel>
      <skos:definition xml:lang="en">SGML – Standard Generalized Markup Language – is a standard for defining generalized markup languages for documents. Generalized markup is based on two postulates: markup should be declarative and rigorous.</skos:definition>
      <dc:identifier>SGML</dc:identifier>
      <atold:op-code>SGML</atold:op-code>
      <at:op-code>SGML</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>SGML</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>text/sgml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-textual-cellar</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>manifestation-type-cellar</dc:source>
            <at:legacy-code>sgml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.sgml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.sgm</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>priority-weight-cellar</dc:source>
            <at:legacy-code>1000</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Standard Generalized Mark-up Language</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:historyNote xml:lang="en">{comment_about_IANA} Registered under 2 values by IANA: text/sgml and application/sgml</skos:historyNote>
      <skos:historyNote xml:lang="en">IANA MIME Media type "application/sgml" not used at the Publications Office no use of a SGML tool.</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/TIFF"
                 at:deprecated="false">
      <euvoc:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">700</euvoc:order>
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">image/tiff</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.tiff</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">image/tiff</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.tif</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">image/tiff-fx</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MANIFT">tiff</skos:notation>
      <skos:prefLabel xml:lang="et">TIFF</skos:prefLabel>
      <skos:prefLabel xml:lang="en">TIFF</skos:prefLabel>
      <skos:definition xml:lang="en">TIFF – Tagged Image File Format – is a computer file format for storing raster graphics images, popular among graphic artists, the publishing industry and photographers. TIFF is widely supported by scanning, faxing, word processing, optical character recognition, image manipulation, desktop publishing and page-layout applications. The format was created by Aldus Corporation for use in desktop publishing.</skos:definition>
      <dc:identifier>TIFF</dc:identifier>
      <atold:op-code>TIFF</atold:op-code>
      <at:op-code>TIFF</at:op-code>
