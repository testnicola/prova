      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.appxbundle</skos:notation>
      <skos:prefLabel xml:lang="et">AppX</skos:prefLabel>
      <skos:prefLabel xml:lang="en">AppX</skos:prefLabel>
      <skos:definition xml:lang="en">AppX is a file format used to distribute and install apps on Windows 8.x and 10, Windows Phone 8.1, Windows 10 Mobile, Xbox One, Hololens and Windows 10 IoT Core.</skos:definition>
