      <skos:altLabel xml:lang="en">Android Package (Oculus)</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/JSON"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.json</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/json</skos:notation>
      <skos:prefLabel xml:lang="en">JSON</skos:prefLabel>
      <skos:prefLabel xml:lang="et">JSON</skos:prefLabel>
      <skos:definition xml:lang="en">JSON is an open-standard file format that uses human-readable text to transmit data objects consisting of attribute–value pairs and array data types (or any other serializable value). It is a very common data format used for asynchronous browser/server communication.</skos:definition>
      <dc:identifier>JSON</dc:identifier>
      <atold:op-code>JSON</atold:op-code>
      <at:op-code>JSON</at:op-code>
      <at:start.use>2006-07-01</at:start.use>
      <at:authority-code>JSON</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.json</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-nonPropExt</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-machine-readable</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">JavaScript Object Notation</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:changeNote xml:lang="en">DCAT proposal 2013-10-01</skos:changeNote>
      <skos:changeNote xml:lang="en">* Documentation: http://www.json.org/ * Classification: DATA because format of data exchanged that need JavaScript to be treated * IMMC_approval_date: empty because "information procedure"</skos:changeNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/PDFUA"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/pdf</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.pdf</skos:notation>
      <skos:prefLabel xml:lang="en">PDF/UA</skos:prefLabel>
      <skos:prefLabel xml:lang="et">PDF/UA</skos:prefLabel>
      <skos:definition xml:lang="en">PDF/UA (PDF/Universal Accessibility), formally ISO 14289, is an International Organization for Standardization (ISO) standard for accessible PDF technology. A technical specification intended for developers implementing PDF writing and processing software, PDF/UA provides definitive terms and requirements for accessibility in PDF documents and applications. For those equipped with appropriate software, conformance with PDF/UA ensures accessibility for people with disabilities who use assistive technology such as screen readers, screen magnifiers, joysticks and other technologies to navigate and read electronic content.</skos:definition>
      <dc:identifier>PDFUA</dc:identifier>
      <atold:op-code>PDFUA</atold:op-code>
      <at:op-code>PDFUA</at:op-code>
      <at:start.use>2012-07-15</at:start.use>
      <at:authority-code>PDFUA</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.pdf</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">PDF/Universal Accessibility</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/ODT"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.odt</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/vnd.oasis.opendocument.text</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/vnd.oasis.opendocument.text</skos:notation>
      <skos:prefLabel xml:lang="en">ODT</skos:prefLabel>
      <skos:prefLabel xml:lang="et">ODT</skos:prefLabel>
      <skos:definition xml:lang="en">ODT is the word processing file format of OpenDocument, an open standard for electronic documents.</skos:definition>
      <dc:identifier>ODT</dc:identifier>
      <atold:op-code>ODT</atold:op-code>
      <at:op-code>ODT</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>ODT</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/vnd.oasis.opendocument.text</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.odt</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Open Document Text</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:changeNote xml:lang="en">DCAT proposal 2013-11-27</skos:changeNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/MXD"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.mxd</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-mxd</skos:notation>
      <skos:prefLabel xml:lang="et">MXD</skos:prefLabel>
      <skos:prefLabel xml:lang="en">MXD</skos:prefLabel>
      <skos:definition xml:lang="en">MXD – Map Exchange Document – is a file format in which the maps created from ArcGIS software can be stored.</skos:definition>
      <dc:identifier>MXD</dc:identifier>
      <atold:op-code>MXD</atold:op-code>
      <at:op-code>MXD</at:op-code>
      <at:start.use>2013-09-18</at:start.use>
      <at:authority-code>MXD</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.mxd</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">ArcGIS Map Document</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:historyNote xml:lang="en">{comment_about_IANA} Not present on IANA website</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/WMTS_SRVC"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">text/xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/gml+xml</skos:notation>
      <skos:prefLabel xml:lang="et">WMTS</skos:prefLabel>
      <skos:prefLabel xml:lang="en">WMTS</skos:prefLabel>
      <skos:definition xml:lang="en">Open Geospatial Consortium’s standard for serving digital maps using predefined image tiles</skos:definition>
      <dc:identifier>WMTS_SRVC</dc:identifier>
      <atold:op-code>WMTS_SRVC</atold:op-code>
      <at:op-code>WMTS_SRVC</at:op-code>
      <at:start.use>2010-04-06</at:start.use>
      <at:authority-code>WMTS_SRVC</at:authority-code>
      <skos:altLabel xml:lang="en">Web Map Tile Service</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/PSD"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.psd</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-photoshop</skos:notation>
      <skos:prefLabel xml:lang="et">PSD</skos:prefLabel>
      <skos:prefLabel xml:lang="en">PSD</skos:prefLabel>
      <skos:definition xml:lang="en">PSD – Photoshop Document – stores an image with support for most imaging options available in Adobe Photoshop. Photoshop is a raster graphics editor.</skos:definition>
      <dc:identifier>PSD</dc:identifier>
      <atold:op-code>PSD</atold:op-code>
      <at:op-code>PSD</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>PSD</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.psd</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Adobe Photoshop Document</skos:altLabel>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} Image file created by Adobe Photoshop, a professional image-editing program; may include image layers, adjustment layers, layer masks, annotation notes, file information, keywords, and other Photoshop-specific elements. Photoshop documents support RGB, CMYK, grayscale, monochrome, duotone, indexed color, Lab color, and multichannel color modes. The color mode can be changed within the Image → Mode submenu. While PSD files are saved in a proprietary format, they can be opened directly with Apple Preview, which is included with Mac OS X. They can be also opened by the media programs included with Windows 7 if the correct codec, such as the Ardfry PSD codec, is installed. These programs include Windows 7 Photo Viewer, Windows 7 Media Center, and Windows Media Player.</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/GPX"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/octet-stream</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.gpx</skos:notation>
      <skos:prefLabel xml:lang="et">GPX</skos:prefLabel>
      <skos:prefLabel xml:lang="en">GPX</skos:prefLabel>
      <skos:definition xml:lang="en">light-weight XML data format for the interchange of GPS data (waypoints, routes, and tracks) between applications and web services</skos:definition>
      <dc:identifier>GPX</dc:identifier>
      <atold:op-code>GPX</atold:op-code>
      <at:op-code>GPX</at:op-code>
      <at:start.use>2002-01-01</at:start.use>
      <at:authority-code>GPX</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.gpx</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-nonPropExt</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">GPS Exchange Format</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/METS"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/xml;type=mets</skos:notation>
      <skos:prefLabel xml:lang="et">METS XML</skos:prefLabel>
      <skos:prefLabel xml:lang="en">METS XML</skos:prefLabel>
      <skos:definition xml:lang="en">METS – Metadata Encoding and Transmission Standard – is a metadata standard for encoding descriptive, administrative and structural metadata regarding objects within a digital library, expressed using the XML schema language.</skos:definition>
      <dc:identifier>METS</dc:identifier>
      <atold:op-code>METS</atold:op-code>
      <at:op-code>METS</at:op-code>
      <at:start.use>2003-10-27</at:start.use>
      <at:authority-code>METS</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/xml;type=mets</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.xml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Metadata Encoding and Transmission Standard – Logical METS container</skos:altLabel>
      <skos:historyNote xml:lang="en">{comment_about_IANA} Not present on IANA website</skos:historyNote>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} METS: OP-code is not "METS_XML" because in OP, the serialisation is always XML. On the other hand, we dropped METS_ZIP, so no need of a suffix</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/GML"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/gml+xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.gml .xml</skos:notation>
      <skos:prefLabel xml:lang="en">GML</skos:prefLabel>
      <skos:prefLabel xml:lang="et">GML</skos:prefLabel>
      <skos:definition xml:lang="en">GML – Geography Markup Language – is the XML grammar defined by the Open Geospatial Consortium (OGC) to express geographical features. GML serves as a modeling language for geographic systems as well as an open interchange format for geographic transactions on the Internet.</skos:definition>
      <dc:identifier>GML</dc:identifier>
      <atold:op-code>GML</atold:op-code>
      <at:op-code>GML</at:op-code>
      <at:start.use>2000-05-01</at:start.use>
      <at:authority-code>GML</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.gml .xml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Geography Markup Language</skos:altLabel>
      <skos:changeNote xml:lang="en">DCAT proposal 2013-11-27</skos:changeNote>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} Geography data format created by Galdos Systems and supported by the Open Geospatial Consortium; used by geographers for storing geographical data in a standard interchangeable format.</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/ODG"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/vnd.oasis.opendocument.graphics</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.odg</skos:notation>
      <skos:prefLabel xml:lang="en">OpenDocument Image</skos:prefLabel>
      <skos:prefLabel xml:lang="et">OpenDocument pilt</skos:prefLabel>
      <skos:definition xml:lang="en">OpenDocument is a standardized Open Document Format for Office Applications. Image files are composed of digital data and are used to organize and store digital images.</skos:definition>
      <dc:identifier>ODG</dc:identifier>
      <atold:op-code>ODG</atold:op-code>
      <at:op-code>ODG</at:op-code>
      <at:start.use>2006-05-31</at:start.use>
      <at:authority-code>ODG</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.odg</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/THRIFT_JSON"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/vnd.apache.thrift.json</skos:notation>
      <skos:prefLabel xml:lang="et">Thrift JSON</skos:prefLabel>
      <skos:prefLabel xml:lang="en">Thrift JSON</skos:prefLabel>
      <skos:definition xml:lang="en">interface definition language and binary communication protocol used for defining and creating services for programming languages; JSON format</skos:definition>
      <dc:identifier>THRIFT_JSON</dc:identifier>
      <atold:op-code>THRIFT_JSON</atold:op-code>
      <at:op-code>THRIFT_JSON</at:op-code>
      <at:start.use>2023-09-02</at:start.use>
      <at:authority-code>THRIFT_JSON</at:authority-code>
      <skos:altLabel xml:lang="en">Apache Thrift JSON format</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/ISO"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.iso</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.img</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-iso9660-image</skos:notation>
      <skos:prefLabel xml:lang="en">ISO image</skos:prefLabel>
      <skos:prefLabel xml:lang="et">ISO pilt</skos:prefLabel>
      <skos:definition xml:lang="en">Archive file containing the content from (or destined for) an optical disk. Originally it was limited to data formatted to comply with the ISO 9660 standard (1988), hence the format name and the iso file extension. The ISO Disk Image File Format is typically used to package or bundle software, databases, authored DVD video programs, and the like. ISO image files, unlike normal files, are not opened but rather are mounted. ISO image files contain the data contents of every written sector of an optical disc, including the optical disc file system if one is present.</skos:definition>
      <dc:identifier>ISO</dc:identifier>
      <atold:op-code>ISO</atold:op-code>
      <at:op-code>ISO</at:op-code>
      <at:start.use>1988-09-01</at:start.use>
      <at:authority-code>ISO</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.iso</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.img</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">ISO Disc Image file</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/RPM"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.rpm</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-rpm</skos:notation>
      <skos:prefLabel xml:lang="en">RPM</skos:prefLabel>
      <skos:prefLabel xml:lang="et">RPM</skos:prefLabel>
      <skos:definition xml:lang="en">File format for RPM Package Manager (originally Red Hat Package Manager), free and open-source package management system.</skos:definition>
      <dc:identifier>RPM</dc:identifier>
      <atold:op-code>RPM</atold:op-code>
      <at:op-code>RPM</at:op-code>
      <at:start.use>1997-01-01</at:start.use>
      <at:authority-code>RPM</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.rpm</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">RPM Package</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/DMG"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.dmg</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-apple-diskimage</skos:notation>
      <skos:prefLabel xml:lang="en">DMG</skos:prefLabel>
      <skos:prefLabel xml:lang="et">DMG</skos:prefLabel>
      <skos:definition xml:lang="en">Apple Disk Image is a disk image format commonly used by the macOS operating system.</skos:definition>
      <dc:identifier>DMG</dc:identifier>
      <atold:op-code>DMG</atold:op-code>
      <at:op-code>DMG</at:op-code>
      <at:start.use>2001-01-01</at:start.use>
      <at:authority-code>DMG</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.dmg</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Apple Disk Image</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/QGS"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/octet-stream</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.qgs</skos:notation>
      <skos:prefLabel xml:lang="et">QGS</skos:prefLabel>
      <skos:prefLabel xml:lang="en">QGS</skos:prefLabel>
      <skos:definition xml:lang="en">QGS file is a Quantum GIS project. Quantum GIS (QGIS) is a cross-platform free and open source desktop geographic information systems (GIS) application that provides data viewing, editing, and analysis capabilities.</skos:definition>
      <dc:identifier>QGS</dc:identifier>
      <atold:op-code>QGS</atold:op-code>
      <at:op-code>QGS</at:op-code>
      <at:start.use>2002-07-01</at:start.use>
      <at:authority-code>QGS</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.qgs</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Quantum GIS project</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/EPS"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/postscript</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/postscript</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.eps</skos:notation>
      <skos:prefLabel xml:lang="en">Encapsulated Postscript</skos:prefLabel>
      <skos:prefLabel xml:lang="et">Kapseldatud Postscript</skos:prefLabel>
      <skos:definition xml:lang="en">EPS – Encapsulated PostScript – files are more-or-less self-contained, reasonably predictable PostScript documents that describe an image or drawing and can be placed within another PostScript document.</skos:definition>
      <dc:identifier>EPS</dc:identifier>
      <atold:op-code>EPS</atold:op-code>
      <at:op-code>EPS</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>EPS</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/postscript</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.eps</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:changeNote xml:lang="en">* PS seems to be never present in the Cellar, which contains always EPS. * ODP has 2 occurrences, but does not want to add EPS to its list yet. Will do it if adds old formats to its list.</skos:changeNote>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} PostScript PS file that may contain 2D vector graphics, bitmap images, and text; may also include an embedded preview image in bitmap format; can be placed within another PostScript document.</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/XLSB"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/vnd.ms-excel.sheet.binary.macroEnabled.12</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.xlsb</skos:notation>
      <skos:prefLabel xml:lang="en">XLSB</skos:prefLabel>
      <skos:prefLabel xml:lang="et">XLSB</skos:prefLabel>
      <skos:definition xml:lang="en">A file with the XLSB file extension is an Excel Binary Workbook file. They store information in binary format instead of XML like with most other Excel files (like XLSX). Since XLSB files are binary, they can be read from and written to much faster, making them extremely useful for very large spreadsheets.</skos:definition>
      <dc:identifier>XLSB</dc:identifier>
      <atold:op-code>XLSB</atold:op-code>
      <at:op-code>XLSB</at:op-code>
      <at:start.use>2007-01-30</at:start.use>
      <at:authority-code>XLSB</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.xlsb</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Excel Binary Workbook</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/GZIP"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/gzip</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.gz</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MANIFT">gzip</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/x-gzip</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-gzip</skos:notation>
      <skos:prefLabel xml:lang="en">GNU zip</skos:prefLabel>
      <skos:prefLabel xml:lang="et">GNU zip</skos:prefLabel>
      <skos:definition xml:lang="en">GZIP – GNU zip – is a file format and a software application used for file compression and decompression.</skos:definition>
      <dc:identifier>GZIP</dc:identifier>
      <atold:op-code>GZIP</atold:op-code>
      <at:op-code>GZIP</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>GZIP</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-nonPropExt</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.gz</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/x-gzip</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>manifestation-type-cellar</dc:source>
            <at:legacy-code>gzip</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:historyNote xml:lang="en">{comment_about_IANA} Not present on IANA website</skos:historyNote>
      <skos:historyNote xml:lang="en">GZIP: Free compression software application, in replacement for the "compress" program used in early Unix systems, and intended for use by the GNU Project.</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/MDB"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/vnd.ms-access</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-msaccess</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.mdb</skos:notation>
      <skos:prefLabel xml:lang="en">MDB</skos:prefLabel>
      <skos:prefLabel xml:lang="et">MDB</skos:prefLabel>
      <skos:definition xml:lang="en">MDB – Microsoft Database – is a proprietary file format used by 2003 and earlier versions of Microsoft Access. Microsoft Access is a database management system.</skos:definition>
      <dc:identifier>MDB</dc:identifier>
      <atold:op-code>MDB</atold:op-code>
      <at:op-code>MDB</at:op-code>
      <at:start.use>2013-09-18</at:start.use>
      <at:authority-code>MDB</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.mdb</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Microsoft Access Database</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:historyNote xml:lang="en">{comment_about_IANA} Not present on IANA website</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/ECW"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.ecw</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-ecw</skos:notation>
      <skos:prefLabel xml:lang="en">ECW</skos:prefLabel>
      <skos:prefLabel xml:lang="et">ECW</skos:prefLabel>
      <skos:definition xml:lang="en">ECW – Enhanced Compressed Wavelet – is the media type which shall be used for a proprietary wavelet compression image format optimized for aerial and satellite imagery.</skos:definition>
      <dc:identifier>ECW</dc:identifier>
      <atold:op-code>ECW</atold:op-code>
      <at:op-code>ECW</at:op-code>
      <at:start.use>1998-01-01</at:start.use>
      <at:authority-code>ECW</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.ecw</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Enhanced Compressed Wavelet</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/KML"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/vnd.google-earth.kml+xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.kml</skos:notation>
      <skos:prefLabel xml:lang="en">KML</skos:prefLabel>
      <skos:prefLabel xml:lang="et">KML</skos:prefLabel>
      <skos:definition xml:lang="en">KML – Keyhole Markup Language – is an XML notation for expressing geographic annotation and visualization within Internet-based, two-dimensional maps and three-dimensional Earth browsers. KML was developed for use with Google Earth and became an international standard.</skos:definition>
      <dc:identifier>KML</dc:identifier>
      <atold:op-code>KML</atold:op-code>
      <at:op-code>KML</at:op-code>
      <at:start.use>2013-09-18</at:start.use>
      <at:authority-code>KML</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.kml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-machine-readable</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-nonPropExt</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Keyhole Markup Language</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:changeNote xml:lang="en">DCAT proposal 2013-11-27</skos:changeNote>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} Stores geographic modeling information in XML format; includes points, lines, polygons, and images; used to identify and label locations, create different camera angles, overlay textures, and add HTML content.</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/LAS"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-las</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.las</skos:notation>
      <skos:prefLabel xml:lang="en">LASer file</skos:prefLabel>
      <skos:prefLabel xml:lang="et">LASer fail</skos:prefLabel>
      <skos:definition xml:lang="en">LAS – LASer file format – is the media type which shall be used for a public file format for the interchange of 3-dimensional point cloud data data between data users.</skos:definition>
      <dc:identifier>LAS</dc:identifier>
      <atold:op-code>LAS</atold:op-code>
      <at:op-code>LAS</at:op-code>
      <at:start.use>2003-05-09</at:start.use>
      <at:authority-code>LAS</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.las</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/RDFA"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.rdfa</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/rdfa</skos:notation>
      <skos:prefLabel xml:lang="et">RDFa</skos:prefLabel>
      <skos:prefLabel xml:lang="en">RDFa</skos:prefLabel>
      <skos:definition xml:lang="en">RDFa is a technique that provides a set of markup attributes to augment the visual information on the Web with machine-readable hints.</skos:definition>
      <dc:identifier>RDFA</dc:identifier>
      <atold:op-code>RDFA</atold:op-code>
      <at:op-code>RDFA</at:op-code>
      <at:start.use>2006-03-10</at:start.use>
      <at:authority-code>RDFA</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.rdfa</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-machine-readable</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Resource Description Framework in Attributes</skos:altLabel>
   </skos:Concept>
