         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">ARJ archive</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/SKOS_XML"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.rdf</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/rdf+xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/rdf+xml;type=skos</skos:notation>
      <skos:prefLabel xml:lang="et">SKOS</skos:prefLabel>
      <skos:prefLabel xml:lang="en">SKOS</skos:prefLabel>
      <skos:definition xml:lang="en">SKOS – Simple Knowledge Organization System – is a W3C recommendation designed for representation of thesauri, classification schemes, taxonomies, subject-heading systems or any other type of structured controlled vocabulary. XML – Extensible Markup Language – is a markup language that defines a set of rules for encoding documents in a format that is both human-readable and machine-readable.</skos:definition>
      <dc:identifier>SKOS_XML</dc:identifier>
      <atold:op-code>SKOS_XML</atold:op-code>
      <at:op-code>SKOS_XML</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>SKOS_XML</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/rdf+xml;type=skos</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.rdf</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Simple Knowledge Organization System</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:historyNote xml:lang="en">{comment_about_IANA} Not present on IANA website</skos:historyNote>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} * SKOS_XML: XML is the serialisation of SKOS * MIME_type_cellar: MWK is ok with "rdf+xml,type=skos"</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/LPK"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
