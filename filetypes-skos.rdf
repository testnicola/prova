         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.xapk</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Android Package</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/DTD_SGML"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.dtd</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/sgml-dtd</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/sgml</skos:notation>
      <skos:prefLabel xml:lang="en">SGML DTD</skos:prefLabel>
      <skos:prefLabel xml:lang="et">SGML DTD</skos:prefLabel>
      <skos:definition xml:lang="en">SGML – Standard Generalized Markup Language – is a standard for defining generalized markup languages for documents. DTD – document type definition – is a set of markup declarations that define a document type for an SGML-family markup language (SGML, XML, HTML). It defines the legal building blocks of an XML document, the document structure with a list of legal elements and attributes.</skos:definition>
      <dc:identifier>DTD_SGML</dc:identifier>
      <atold:op-code>DTD_SGML</atold:op-code>
      <at:op-code>DTD_SGML</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>DTD_SGML</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.dtd</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/sgml-dtd</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">SGML Document Type Definition (DTD)</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:historyNote xml:lang="en">{comment_about_IANA} Not present on IANA website</skos:historyNote>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} DTD_SGML: SGML is not a serialisation of the DTD, but the DTD is expressed FOR SGML. The rule here is the pattern: general_particular</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/TSV"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.tab</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.tsv</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">text/tab-separated-values</skos:notation>
      <skos:prefLabel xml:lang="et">TSV</skos:prefLabel>
      <skos:prefLabel xml:lang="en">TSV</skos:prefLabel>
      <skos:definition xml:lang="en">TSV – tab-separated values – files are a simple text format for storing data in a tabular structure, e.g. database table or spreadsheet data, and a way of exchanging information between databases. Each record in the table is one line of the text file. Each field value of a record is separated from the next by a tab character.</skos:definition>
      <dc:identifier>TSV</dc:identifier>
      <atold:op-code>TSV</atold:op-code>
      <at:op-code>TSV</at:op-code>
      <at:start.use>2013-10-02</at:start.use>
      <at:authority-code>TSV</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.tsv</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.tab</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-nonPropExt</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Tab-Separated Value</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:changeNote xml:lang="en">DCAT proposal 2013-10-01</skos:changeNote>
      <skos:changeNote xml:lang="en">* IMMC_approval_date: empty because "information procedure"</skos:changeNote>
      <skos:historyNote xml:lang="en">Format for tabular data exchange</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/GDB"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.gdb</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-filegdb</skos:notation>
      <skos:prefLabel xml:lang="en">Esri File Geodatabase</skos:prefLabel>
      <skos:prefLabel xml:lang="et">Esri File geoandmebaas</skos:prefLabel>
      <skos:definition xml:lang="en">GDB is an Esri's file-based geodatabase format, stored as folders in a file system. It shall be used for Esri file geodatabases. The file is a zip archive that contains the gdb directory.</skos:definition>
      <dc:identifier>GDB</dc:identifier>
      <atold:op-code>GDB</atold:op-code>
      <at:op-code>GDB</at:op-code>
      <at:start.use>2008-02-06</at:start.use>
      <at:authority-code>GDB</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.gdb</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Environmental Systems Research Institute File Geodatabase</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/JPEG2000"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.jp2</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.jpg2</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">image/jp2</skos:notation>
      <skos:prefLabel xml:lang="et">JPEG 2000</skos:prefLabel>
      <skos:prefLabel xml:lang="en">JPEG 2000</skos:prefLabel>
      <skos:definition xml:lang="en">JPEG 2000 – Joint Photographic Experts Group 2000 – is an image coding system that uses state-of-the-art compression techniques based on wavelet technology.</skos:definition>
      <dc:identifier>JPEG2000</dc:identifier>
      <atold:op-code>JPEG2000</atold:op-code>
      <at:op-code>JPEG2000</at:op-code>
