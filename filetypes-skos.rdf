      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Open Virtualization Format</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/SDMX"
