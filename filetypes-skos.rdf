      <skos:prefLabel xml:lang="et">PNG</skos:prefLabel>
      <skos:prefLabel xml:lang="en">PNG</skos:prefLabel>
      <skos:definition xml:lang="en">PNG – Portable Network Graphics – is a raster graphics file format that supports lossless data compression. PNG was created as an improved, non-patented replacement for Graphics Interchange Format (GIF), and is the most widely used lossless image compression format on the Internet.</skos:definition>
      <dc:identifier>PNG</dc:identifier>
      <atold:op-code>PNG</atold:op-code>
      <at:op-code>PNG</at:op-code>
