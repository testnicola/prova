      <skos:altLabel xml:lang="en">iOS App Store Package</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/DTD_XML"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.dtd</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/xml-dtd</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/xml-dtd</skos:notation>
      <skos:prefLabel xml:lang="en">XML DTD</skos:prefLabel>
      <skos:prefLabel xml:lang="et">XML DTD</skos:prefLabel>
      <skos:definition xml:lang="en">XML – Extensible Markup Language – is a markup language that defines a set of rules for encoding documents in a format that is both human-readable and machine-readable. DTD – document type definition – is a set of markup declarations that define a document type for an SGML-family markup language (SGML, XML, HTML). It defines the legal building blocks of an XML document, the document structure with a list of legal elements and attributes. XML uses a subset of SGML DTD.</skos:definition>
      <dc:identifier>DTD_XML</dc:identifier>
      <atold:op-code>DTD_XML</atold:op-code>
      <at:op-code>DTD_XML</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>DTD_XML</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/xml-dtd</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.dtd</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">XML Document Type Definition (DTD)</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} See DTD_SGML</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/PPS"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/vnd.ms-powerpoint</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/vnd.ms-powerpoint</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.pps</skos:notation>
      <skos:prefLabel xml:lang="et">PowerPoint slaidiesitlus</skos:prefLabel>
      <skos:prefLabel xml:lang="en">PowerPoint Slide Show</skos:prefLabel>
      <skos:definition xml:lang="en">PPS – PowerPoint 97–2003 binary slide show – is a binary filaname extension of Microsoft PowerPoint presentation program. PowerPoint was originally designed to provide visuals for group presentations within business organizations, but has come to be very widely used in many other communication situations, both in business and beyond.</skos:definition>
      <dc:identifier>PPS</dc:identifier>
      <atold:op-code>PPS</atold:op-code>
      <at:op-code>PPS</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>PPS</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.pps</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/vnd.ms-powerpoint</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Microsoft PowerPoint Slide Show</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} * PPS: has same template as Word, but for PowerPoint. * PPT and PPS are technically identical. When you open PPS, the mode "slideshow" is automatically activated &gt;&lt; PPT: mode modifying, with all icons * PPS is never used in Cellar</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/MRSID"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.sid</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">image/x-mrsid</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">image/x.mrsid</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">image/x-mrsid-image</skos:notation>
      <skos:prefLabel xml:lang="en">MrSID</skos:prefLabel>
      <skos:prefLabel xml:lang="et">MrSID</skos:prefLabel>
      <skos:definition xml:lang="en">Multiresolution seamless image database (MrSID) is a file format developed and patented by LizardTech for encoding of georeferenced raster graphics, such as orthophotos. With this format, large raster image files such as aerial photographs or satellite imagery are compressed and can be quickly viewed without having to decompress the entire file.</skos:definition>
      <dc:identifier>MRSID</dc:identifier>
      <atold:op-code>MRSID</atold:op-code>
      <at:op-code>MRSID</at:op-code>
      <at:start.use>1996-01-01</at:start.use>
      <at:authority-code>MRSID</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.sid</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Multiresolution seamless image database</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/LZMA"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.lzma</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-lzma</skos:notation>
      <skos:prefLabel xml:lang="et">lzma</skos:prefLabel>
      <skos:prefLabel xml:lang="en">lzma</skos:prefLabel>
      <skos:definition xml:lang="en">Compressed file produced using LZMA (Lempel-Ziv-Markov) chain algorithm.</skos:definition>
      <dc:identifier>LZMA</dc:identifier>
      <atold:op-code>LZMA</atold:op-code>
      <at:op-code>LZMA</at:op-code>
      <at:start.use>2000-01-01</at:start.use>
      <at:authority-code>LZMA</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.lzma</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">lzma compressed file</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/BZIP2"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-bzip2</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.bz2</skos:notation>
      <skos:prefLabel xml:lang="et">bzip2</skos:prefLabel>
      <skos:prefLabel xml:lang="en">bzip2</skos:prefLabel>
      <skos:definition xml:lang="en">An open source, patent- and royalty-free compression format. The compression algorithm is a Burrows-Wheeler transform followed by a move-to-front transform and finally Huffman coding.</skos:definition>
      <dc:identifier>BZIP2</dc:identifier>
      <atold:op-code>BZIP2</atold:op-code>
      <at:op-code>BZIP2</at:op-code>
      <at:start.use>1996-07-18</at:start.use>
      <at:authority-code>BZIP2</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.bz2</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">bzip2 compressed file</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/TAB_RSTR"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.tab</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-tab-raster</skos:notation>
      <skos:prefLabel xml:lang="en">MapInfo TAB raster file</skos:prefLabel>
      <skos:prefLabel xml:lang="et">MapInfo TAB rasterfail</skos:prefLabel>
      <skos:definition xml:lang="en">MapInfo TAB raster file is the media type which shall be used for the MapInfo Raster TAB format. This media type is incomplete as it lacks a reference to the specification of the format.</skos:definition>
      <dc:identifier>TAB_RSTR</dc:identifier>
      <atold:op-code>TAB_RSTR</atold:op-code>
      <at:op-code>TAB_RSTR</at:op-code>
      <at:start.use>2000-03-26</at:start.use>
      <at:authority-code>TAB_RSTR</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.tab</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/XLIFF"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.xlf</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/xliff+xml</skos:notation>
      <skos:prefLabel xml:lang="et">XLIFF</skos:prefLabel>
      <skos:prefLabel xml:lang="en">XLIFF</skos:prefLabel>
      <skos:definition xml:lang="en">XLIFF is the XML Localisation Interchange File Format designed by a group of multilingual content publishers, software providers, localization service providers, localization tools providers and researchers. It is intended to give any multilingual content owner a single interchange file format that can be understood by any localization provider, using any conformant localization tool. While the primary focus is on being a lossless interchange format, usage of XLIFF as a processing format is neither encouraged nor discouraged or prohibited.</skos:definition>
      <dc:identifier>XLIFF</dc:identifier>
      <atold:op-code>XLIFF</atold:op-code>
      <at:op-code>XLIFF</at:op-code>
      <at:start.use>2001-05-30</at:start.use>
      <at:authority-code>XLIFF</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.xlf</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">XML Localisation Interchange File Format</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/MAP_SRVC"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">arcgis_map_service</skos:notation>
      <skos:prefLabel xml:lang="en">ArcGIS Map Service</skos:prefLabel>
      <skos:prefLabel xml:lang="et">ArcGIS Map teenus</skos:prefLabel>
      <skos:definition xml:lang="en">Esri's ArcGIS is a geographic information system (GIS) for working with maps and geographic information. Map services offer access to map and layer content.</skos:definition>
      <dc:identifier>MAP_SRVC</dc:identifier>
      <atold:op-code>MAP_SRVC</atold:op-code>
      <at:op-code>MAP_SRVC</at:op-code>
      <at:start.use>2010-01-01</at:start.use>
      <at:authority-code>MAP_SRVC</at:authority-code>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/DAPK"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/vnd.android.package-archive</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.apk</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.xapk</skos:notation>
      <skos:prefLabel xml:lang="en">DAPK</skos:prefLabel>
      <skos:prefLabel xml:lang="et">DAPK</skos:prefLabel>
      <skos:definition xml:lang="en">An Android Package (APK) with special features used by the Android operating system for the distribution and installation of Daydream mobile apps.</skos:definition>
      <dc:identifier>DAPK</dc:identifier>
      <atold:op-code>DAPK</atold:op-code>
      <at:op-code>DAPK</at:op-code>
      <at:start.use>2022-04-06</at:start.use>
      <at:authority-code>DAPK</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.apk</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.xapk</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Android Package (Daydream)</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/GRID"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-grid</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-esri-grid</skos:notation>
      <skos:prefLabel xml:lang="en">Esri binary grid</skos:prefLabel>
      <skos:prefLabel xml:lang="et">Esri binaarne ruutkava</skos:prefLabel>
      <skos:definition xml:lang="en">Esri binary grid is a proprietary binary variation of an Esri grid, a raster GIS file format developed by Esri. It is also known as an ARC/INFO GRID or ARC GRID. It differs from the other Esri grid variation, a non-proprietary ASCII format.</skos:definition>
      <dc:identifier>GRID</dc:identifier>
      <atold:op-code>GRID</atold:op-code>
      <at:op-code>GRID</at:op-code>
      <at:start.use>2013-08-21</at:start.use>
      <at:authority-code>GRID</at:authority-code>
      <skos:altLabel xml:lang="en">Environmental Systems Research Institute binary grid</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/GMZ"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-gmz</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.gmz</skos:notation>
      <skos:prefLabel xml:lang="et">Tihendatud GML</skos:prefLabel>
      <skos:prefLabel xml:lang="en">Zipped GML</skos:prefLabel>
      <skos:definition xml:lang="en">GMZ is the media type which shall be used for a zip archive that contains one or more GML documents.</skos:definition>
      <dc:identifier>GMZ</dc:identifier>
      <atold:op-code>GMZ</atold:op-code>
      <at:op-code>GMZ</at:op-code>
      <at:start.use>2013-09-03</at:start.use>
      <at:authority-code>GMZ</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.gmz</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Zipped Geography Markup Language</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/XSLFO"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.fo</skos:notation>
      <skos:prefLabel xml:lang="en">XSL-FO</skos:prefLabel>
      <skos:prefLabel xml:lang="et">XSL-FO</skos:prefLabel>
      <skos:definition xml:lang="en">XSL-FO – XSL Formatting Objects – is a markup language for XML document formatting that is most often used to generate PDF files. XSL-FO is part of XSL (Extensible Stylesheet Language), a set of W3C technologies designed for the transformation and formatting of XML data.</skos:definition>
      <dc:identifier>XSLFO</dc:identifier>
      <atold:op-code>XSLFO</atold:op-code>
      <at:op-code>XSLFO</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>XSLFO</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.fo</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Extensible Stylesheet Language – Formatting Objects</skos:altLabel>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} * Intermediary format based on XML. Conversion is: XML &gt; XSLFO &gt; PDF * IANA: not found on "application"</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/XYZ"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">chemical/x-pdb</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.xyz</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">chemical/x-xyz</skos:notation>
      <skos:prefLabel xml:lang="en">XYZ Chemical File</skos:prefLabel>
      <skos:prefLabel xml:lang="et">XYZ keemiline fail</skos:prefLabel>
      <skos:definition xml:lang="en">The XYZ file format is a chemical file format. There is no formal standard and several variations exist, but a typical XYZ format specifies the molecule geometry by giving the number of atoms with Cartesian coordinates that will be read on the first line, a comment on the second, and the lines of atomic coordinates in the following lines.</skos:definition>
      <dc:identifier>XYZ</dc:identifier>
      <atold:op-code>XYZ</atold:op-code>
      <at:op-code>XYZ</at:op-code>
      <at:start.use>2010-10-10</at:start.use>
      <at:authority-code>XYZ</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.xyz</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>chemical/x-pdb</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/ARCINFO_COV"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">multipart/mixed</skos:notation>
      <skos:prefLabel xml:lang="et">ArcInfo coverage</skos:prefLabel>
      <skos:prefLabel xml:lang="en">ArcInfo coverage</skos:prefLabel>
      <skos:definition xml:lang="en">An ESRI ArcInfo coverage is a georelational data model that stores vector data – it contains both the spatial (location) and attribute (descriptive) data for geographic features. Coverages use a set of feature classes to represent geographic features. Each feature class stores a set of points, lines (arcs), polygons, or annotation (text). Coverages can have topology, which determines the relationships between features. A coverage is stored as a directory within which each feature class is stored as a set of files.</skos:definition>
      <dc:identifier>ARCINFO_COV</dc:identifier>
      <atold:op-code>ARCINFO_COV</atold:op-code>
      <at:op-code>ARCINFO_COV</at:op-code>
      <at:start.use>1982-01-01</at:start.use>
      <at:authority-code>ARCINFO_COV</at:authority-code>
      <skos:altLabel xml:lang="en">ESRI ArcInfo Coverage</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/AAB"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-authorware-bin</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.aab</skos:notation>
      <skos:prefLabel xml:lang="et">AAB</skos:prefLabel>
      <skos:prefLabel xml:lang="en">AAB</skos:prefLabel>
      <skos:definition xml:lang="en">An Android App Bundle (AAB) is a package file format used by the Android operating system. It includes an app’s compiled code and resources, and defers APK generation and signing to Google Play.</skos:definition>
      <dc:identifier>AAB</dc:identifier>
      <atold:op-code>AAB</atold:op-code>
      <at:op-code>AAB</at:op-code>
      <at:start.use>2021-08-01</at:start.use>
      <at:authority-code>AAB</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.aab</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Android App Bundle</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/PS"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.ps</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/postscript</skos:notation>
      <skos:prefLabel xml:lang="et">PS</skos:prefLabel>
      <skos:prefLabel xml:lang="en">PS</skos:prefLabel>
      <skos:definition xml:lang="en">PS – PostScript – is a page description language in the electronic publishing and desktop publishing business. It is a dynamically typed, concatenative programming language.</skos:definition>
      <dc:identifier>PS</dc:identifier>
      <atold:op-code>PS</atold:op-code>
      <at:op-code>PS</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>PS</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.ps</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">PostScript File</skos:altLabel>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} Image saved in the PostScript page description language; may contain vector graphics, raster graphics, and text; can be printed directly by a PostScript printer i.e., containing a Raster Image Processor without being opened in an application. PS files have largely been replaced by other page layout file formats, such as .PDF. Yet, they are still supported by many printers and programs. In general, they can be opened by any printer utility that supports PostScript. NOTE: You can convert PS files to PDFs using Acrobat Distiller, a program included with Adobe Acrobat.</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/KMZ"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.kmz</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/vnd.google-earth.kmz</skos:notation>
      <skos:prefLabel xml:lang="en">KMZ</skos:prefLabel>
      <skos:prefLabel xml:lang="et">KMZ</skos:prefLabel>
      <skos:definition xml:lang="en">A KMZ file consists of a main KML file and zero or more supporting files that are packaged using a Zip utility into one unit, called an archive. The KMZ file can then be stored and emailed as a single entity. A NetworkLink can fetch a KMZ file from a web server. When the KMZ file is unzipped, the main .kml file and its supporting files are separated into their original formats and directory structure, with their original filenames and extensions. In addition to being an archive format, the Zip format is also compressed, so an archive can include only a single large KML file. Depending on the content of the KML file, this process typically results in 10:1 compression. Your 10 Kbyte KML file can be served with a 1 Kbyte KMZ file.</skos:definition>
      <dc:identifier>KMZ</dc:identifier>
      <atold:op-code>KMZ</atold:op-code>
      <at:op-code>KMZ</at:op-code>
      <at:start.use>2013-11-27</at:start.use>
      <at:authority-code>KMZ</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-nonPropExt</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.kmz</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-machine-readable</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Keyhole Markup Language, Zipped</skos:altLabel>
      <skos:changeNote xml:lang="en">DCAT proposal 2013-11-27</skos:changeNote>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} Stores map locations viewable in Google Earth, a global mapping program; provides a bird's eye view of locations throughout the U.S. and other areas of the world; placemarks may include a custom name and the latitudinal and longitudinal coordinates of the location. KMZ files may also include limited 3D model data exported from Google Sketchup as an .SKP file or from ArchiCAD. The model can be placed on the map at a specific location to provide an idea of what the building will look like in that area. KMZ files are zipped .KML files, which make them easier to distribute and share with multiple users. NOTE: You can open a KMZ file in Google Maps by saving the KMZ file to an online location and then typing the URL in the Google Maps search box.</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/BMP"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.bm</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">image/x-ms-bmp</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.dib</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.bmp</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">image/bmp</skos:notation>
      <skos:prefLabel xml:lang="en">Bitmap Image File</skos:prefLabel>
      <skos:prefLabel xml:lang="et">Bitmap pildifail</skos:prefLabel>
      <skos:definition xml:lang="en">The bitmap image (BMP) or device independent bitmap (DIB) is a raster graphics image file format used to store bitmap digital images, independently of the display device.</skos:definition>
      <dc:identifier>BMP</dc:identifier>
      <atold:op-code>BMP</atold:op-code>
      <at:op-code>BMP</at:op-code>
      <at:start.use>1996-04-01</at:start.use>
      <at:authority-code>BMP</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.bmp</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>image/bmp</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-nonPropExt</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.bm</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.dib</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/ODP"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.fodp</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/vnd.oasis.opendocument.presentation</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.odp</skos:notation>
      <skos:prefLabel xml:lang="et">ODP</skos:prefLabel>
      <skos:prefLabel xml:lang="en">ODP</skos:prefLabel>
      <skos:definition xml:lang="en">ODP is an OpenDocument file format for presentations. OpenDocument was developed with the aim of providing an open, XML-based file format specification for office applications.</skos:definition>
      <dc:identifier>ODP</dc:identifier>
      <atold:op-code>ODP</atold:op-code>
      <at:op-code>ODP</at:op-code>
      <at:start.use>2005-05-01</at:start.use>
      <at:authority-code>ODP</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.fodp</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.odp</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">OpenDocument Presentation</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/EFORMS_XML"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MANIFT">eforms_xml</skos:notation>
      <skos:prefLabel xml:lang="en">eForms XML</skos:prefLabel>
      <skos:prefLabel xml:lang="et">eForms XML</skos:prefLabel>
      <skos:definition xml:lang="en">EU legislative XML standard for procurement data used by public buyers to publish notices on Tenders Electronic Daily (TED), the European public procurement advertising website. The standard forms (eForms) have been established by the Commission Implementing Regulation (EU) 2019/1780 of 23 September 2019, and need to be implemented in national eProcurement systems by being tailored to national needs.</skos:definition>
      <dc:identifier>EFORMS_XML</dc:identifier>
      <atold:op-code>EFORMS_XML</atold:op-code>
      <at:op-code>EFORMS_XML</at:op-code>
      <at:start.use>2022-11-14</at:start.use>
      <at:authority-code>EFORMS_XML</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.xml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>manifestation-type-cellar</dc:source>
            <at:legacy-code>eforms_xml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/xml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">eForms XML file</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/BIN"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/octet-stream</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/octet-stream</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.bin</skos:notation>
      <skos:prefLabel xml:lang="en">Binary Data</skos:prefLabel>
      <skos:prefLabel xml:lang="et">Binaarsed andmed</skos:prefLabel>
      <skos:definition xml:lang="en">A binary file is a computer file that is not a text file.</skos:definition>
      <dc:identifier>BIN</dc:identifier>
      <atold:op-code>BIN</atold:op-code>
