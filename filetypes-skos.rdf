   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/PDFA3"
                 at:deprecated="false">
      <euvoc:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2440</euvoc:order>
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/pdf</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.pdf</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MANIFT">pdfa3</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/pdf;type=pdfa3</skos:notation>
      <skos:prefLabel xml:lang="en">PDFA-3</skos:prefLabel>
      <skos:prefLabel xml:lang="et">PDFA-3</skos:prefLabel>
      <skos:definition xml:lang="en">PDFA-3 is the Part 3 of the standard which differs from PDF/A-2 in only one regard – it allows embedding of arbitrary file formats (such as XML, CSV, CAD, word-processing documents, spreadsheet documents and others) into PDF/A conforming documents.</skos:definition>
      <dc:identifier>PDFA3</dc:identifier>
      <atold:op-code>PDFA3</atold:op-code>
      <at:op-code>PDFA3</at:op-code>
      <at:start.use>2012-12-15</at:start.use>
      <at:authority-code>PDFA3</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/pdf;type=pdfa3</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>manifestation-type-cellar</dc:source>
