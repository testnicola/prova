      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/PDFX4"
                 at:deprecated="false">
