         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/octet-stream</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/YAML"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/octet-stream</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.yaml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.yml</skos:notation>
      <skos:prefLabel xml:lang="et">YAML</skos:prefLabel>
      <skos:prefLabel xml:lang="en">YAML</skos:prefLabel>
      <skos:definition xml:lang="en">YAML is a human-friendly, cross language, Unicode based data serialization language designed around the common native data types of dynamic programming languages. It is broadly useful for programming needs ranging from configuration files to internet messaging to object persistence to data auditing and visualization.</skos:definition>
      <dc:identifier>YAML</dc:identifier>
      <atold:op-code>YAML</atold:op-code>
      <at:op-code>YAML</at:op-code>
      <at:start.use>2001-05-11</at:start.use>
      <at:authority-code>YAML</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.yaml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.yml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">YAML Ain't Markup Language</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/GRID_ASCII"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-ascii-grid</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.asc</skos:notation>
      <skos:prefLabel xml:lang="et">Esri ASCII ruutkava</skos:prefLabel>
      <skos:prefLabel xml:lang="en">Esri ASCII grid</skos:prefLabel>
      <skos:definition xml:lang="en">Esri ASCII grid is the media type which shall be used for ASCII GRID files. ASCII GRID is one of the two formats of Esri grid, a raster GIS file format, a non-proprietary ASCII format, also known as an ArcInfo ASCII GRID.</skos:definition>
      <dc:identifier>GRID_ASCII</dc:identifier>
      <atold:op-code>GRID_ASCII</atold:op-code>
      <at:op-code>GRID_ASCII</at:op-code>
      <at:start.use>2013-08-21</at:start.use>
      <at:authority-code>GRID_ASCII</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.asc</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Environmental Systems Research Institute ASCII grid</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/BITS"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/xml</skos:notation>
      <skos:prefLabel xml:lang="en">BITS XML</skos:prefLabel>
      <skos:prefLabel xml:lang="et">BITS XML</skos:prefLabel>
      <skos:definition xml:lang="en">BITS – Book Interchange Tag Suite – is the ‘book version’ of Journal Article Tag Suite (JATS); an XML format used to describe books published online. BITS provides a common XML format in which publishers and archivists can describe textual and graphical content elements. In order to facilitate the reusability, BITS makes a tag set adequate for supporting interchange, archiving, format-conversion and publishing.</skos:definition>
      <dc:identifier>BITS</dc:identifier>
      <atold:op-code>BITS</atold:op-code>
      <at:op-code>BITS</at:op-code>
      <at:start.use>2012-08-22</at:start.use>
      <at:authority-code>BITS</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.xml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Book Interchange Tag Suite</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/WAV"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.wave</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.wav</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">audio/vnd.wave</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">audio/x-wav</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">audio/wave</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">audio/wav</skos:notation>
      <skos:prefLabel xml:lang="et">WAV</skos:prefLabel>
      <skos:prefLabel xml:lang="en">WAV</skos:prefLabel>
      <skos:definition xml:lang="en">Waveform Audio File (WAV) is a format is used for storing uncompressed digital audio files. It is the default audio format for Windows but it is supported by most operating systems.</skos:definition>
      <dc:identifier>WAV</dc:identifier>
      <atold:op-code>WAV</atold:op-code>
      <at:op-code>WAV</at:op-code>
      <at:start.use>1991-08-01</at:start.use>
      <at:authority-code>WAV</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
