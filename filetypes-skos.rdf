      <skos:prefLabel xml:lang="en">WAR</skos:prefLabel>
      <skos:prefLabel xml:lang="et">WAR</skos:prefLabel>
      <skos:definition xml:lang="en">A WAR file is used to distribute a collection of JAR-files, JavaServer Pages, Java Servlets, Java classes, XML files, tag libraries, static web pages and other resources that together constitute a web application.</skos:definition>
      <dc:identifier>WAR</dc:identifier>
      <atold:op-code>WAR</atold:op-code>
      <at:op-code>WAR</at:op-code>
