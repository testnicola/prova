   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/WMS_SRVC"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">text/xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/vnd.ogc.wms_xml</skos:notation>
      <skos:prefLabel xml:lang="en">WMS</skos:prefLabel>
      <skos:prefLabel xml:lang="et">WMS</skos:prefLabel>
      <skos:definition xml:lang="en">A Web Map Service (WMS) is a standard protocol developed by the Open Geospatial Consortium (OGC) for serving georeferenced map images over the Internet. These images are typically produced by a map server from data provided by a geographic information system (GIS) database.</skos:definition>
      <dc:identifier>WMS_SRVC</dc:identifier>
      <atold:op-code>WMS_SRVC</atold:op-code>
      <at:op-code>WMS_SRVC</at:op-code>
      <at:start.use>1999-01-01</at:start.use>
      <at:authority-code>WMS_SRVC</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-nonPropExt</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Web Map Service</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/MSG_HTTP"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">message/http</skos:notation>
      <skos:prefLabel xml:lang="et">HTTP sõnum</skos:prefLabel>
      <skos:prefLabel xml:lang="en">HTTP Message</skos:prefLabel>
      <skos:definition xml:lang="en">HTTP – Hypertext Transfer Protocol – is a stateless application-level request/response protocol that uses extensible semantics and self-descriptive message payloads for flexible interaction with network-based hypertext information systems. Message Syntax and Routing is part of the HTTP/1.1 specification.</skos:definition>
      <dc:identifier>MSG_HTTP</dc:identifier>
      <atold:op-code>MSG_HTTP</atold:op-code>
      <at:op-code>MSG_HTTP</at:op-code>
      <at:start.use>2014-06-01</at:start.use>
      <at:authority-code>MSG_HTTP</at:authority-code>
      <skos:altLabel xml:lang="en">HTTP Message Syntax and Routing</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/SCHEMA_XML"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.xsd</skos:notation>
      <skos:prefLabel xml:lang="en">XML schema</skos:prefLabel>
      <skos:prefLabel xml:lang="et">XML skeem</skos:prefLabel>
      <skos:definition xml:lang="en">An XML schema is a description of a type of XML document, typically expressed in terms of constraints on the structure and content of documents of that type, above and beyond the basic syntactical constraints imposed by XML itself.</skos:definition>
      <dc:identifier>SCHEMA_XML</dc:identifier>
      <atold:op-code>SCHEMA_XML</atold:op-code>
      <at:op-code>SCHEMA_XML</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>SCHEMA_XML</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.xsd</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">XML Schema</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} SCHEMA_XML: pattern done per analogy to DTD_SGML because there is no schema in sth else than XML...</skos:historyNote>
   </skos:Concept>
