      <skos:prefLabel xml:lang="et">MOP</skos:prefLabel>
      <skos:prefLabel xml:lang="en">MOP</skos:prefLabel>
      <skos:definition xml:lang="en">MOP is a chemical file format used by MOPAC. MOPAC is a popular computer program used in computational chemistry. It is designed to implement semi-empirical quantum chemistry algorithms.</skos:definition>
      <dc:identifier>MOP</dc:identifier>
      <atold:op-code>MOP</atold:op-code>
