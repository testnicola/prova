      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>manifestation-type-cellar</dc:source>
            <at:legacy-code>rtf</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Rich Text Format File</skos:altLabel>
      <skos:historyNote xml:lang="en">IANA MIME Media type "application/rtf" not used at the Publications Office.</skos:historyNote>
      <skos:historyNote xml:lang="en">{comment_about_IANA} Registered under 2 values by IANA: "text/rtf" and "application/rtf"</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/PDFX1A"
                 at:deprecated="false">
