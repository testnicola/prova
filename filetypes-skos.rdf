      <skos:prefLabel xml:lang="et">IKalender</skos:prefLabel>
      <skos:prefLabel xml:lang="en">ICalendar</skos:prefLabel>
      <skos:definition xml:lang="en">iCalendar is a computer file format which allows Internet users to send meeting requests and tasks to other Internet users by sharing or sending files in this format through various methods.</skos:definition>
      <dc:identifier>ICS</dc:identifier>
      <atold:op-code>ICS</atold:op-code>
      <at:op-code>ICS</at:op-code>
