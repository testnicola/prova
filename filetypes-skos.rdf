      <skos:prefLabel xml:lang="en">SDMX</skos:prefLabel>
      <skos:prefLabel xml:lang="et">SDMX</skos:prefLabel>
      <skos:definition xml:lang="en">SDMX is an initiative to foster standards for the exchange of statistical information. The SDMX message formats have two basic expressions, SDMX-ML (using XML syntax) and SDMX-EDI (using EDIFACT syntax and based on the GESMES/TS statistical message).</skos:definition>
      <dc:identifier>SDMX</dc:identifier>
      <atold:op-code>SDMX</atold:op-code>
      <at:op-code>SDMX</at:op-code>
      <at:start.use>2001-01-01</at:start.use>
      <at:authority-code>SDMX</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.edi</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.xml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Statistical Data and Metadata eXchange</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/DCR"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/x-director</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.dcr</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-director</skos:notation>
      <skos:prefLabel xml:lang="en">DCR File</skos:prefLabel>
      <skos:prefLabel xml:lang="et">DCR fail</skos:prefLabel>
      <skos:definition xml:lang="en">DCR is a file type for Adobe Shockwave Media files. DCR files are used to create games and other highly interactive content.</skos:definition>
      <dc:identifier>DCR</dc:identifier>
      <atold:op-code>DCR</atold:op-code>
      <at:op-code>DCR</at:op-code>
      <at:start.use>1988-01-01</at:start.use>
      <at:authority-code>DCR</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/x-director</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.dcr</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/ARC_GZ"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/gzip</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.arc.gz</skos:notation>
      <skos:prefLabel xml:lang="et">ARC GZ</skos:prefLabel>
      <skos:prefLabel xml:lang="en">ARC GZ</skos:prefLabel>
      <skos:definition xml:lang="en">ARC is the archive file format of Internet Archive. ARC files are large aggregate files. ARC GZ is ARC compressed by GZIP.</skos:definition>
      <dc:identifier>ARC_GZ</dc:identifier>
      <atold:op-code>ARC_GZ</atold:op-code>
      <at:op-code>ARC_GZ</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>ARC_GZ</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.arc.gz</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Compressed Internet Archive ARC file format</skos:altLabel>
   </skos:Concept>
</rdf:RDF>
