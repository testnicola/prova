      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.n3</skos:notation>
      <skos:prefLabel xml:lang="et">N3</skos:prefLabel>
      <skos:prefLabel xml:lang="en">N3</skos:prefLabel>
      <skos:definition xml:lang="en">Non-XML serialization of Resource Description Framework models.</skos:definition>
      <dc:identifier>N3</dc:identifier>
      <atold:op-code>N3</atold:op-code>
      <at:op-code>N3</at:op-code>
      <at:start.use>2008-01-01</at:start.use>
      <at:authority-code>N3</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
