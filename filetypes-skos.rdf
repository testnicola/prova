      <skos:prefLabel xml:lang="et">MP3</skos:prefLabel>
      <skos:prefLabel xml:lang="en">MP3</skos:prefLabel>
      <skos:definition xml:lang="en">An MP3 is a format for digital audio. It uses the lossy compression to reduce the data without losing audio quality.</skos:definition>
      <dc:identifier>MP3</dc:identifier>
      <atold:op-code>MP3</atold:op-code>
      <at:op-code>MP3</at:op-code>
