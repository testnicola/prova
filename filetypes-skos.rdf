   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/ODF"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/octet-stream</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/vnd.oasis.opendocument.formula</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.odf</skos:notation>
      <skos:prefLabel xml:lang="et">ODF</skos:prefLabel>
      <skos:prefLabel xml:lang="en">ODF</skos:prefLabel>
      <skos:definition xml:lang="en">ODF – Open Document Format for Office Applications, also known as OpenDocument – is an XML-based file format for spreadsheets, charts, presentations and word processing documents. It was developed with the aim of providing an open, XML-based file format specification for office applications.</skos:definition>
      <dc:identifier>ODF</dc:identifier>
      <atold:op-code>ODF</atold:op-code>
      <at:op-code>ODF</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>ODF</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.odf</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">OpenDocument Format</skos:altLabel>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} Open Document Format ODF is an international family of standards that is the successor of commonly used deprecated vendor specific document formats such as .doc, .wpd, .xls and .rtf. ODF is standardised at OASIS</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/APPX"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
