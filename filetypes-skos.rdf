      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.jar</skos:notation>
      <skos:prefLabel xml:lang="en">JAR</skos:prefLabel>
      <skos:prefLabel xml:lang="et">JAR</skos:prefLabel>
      <skos:definition xml:lang="en">JAR (Java Archive) is an archive file that includes a Java-specific manifest file. It is built on the ZIP format.</skos:definition>
