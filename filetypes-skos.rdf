   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/LZIP"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-lzip</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.lz</skos:notation>
      <skos:prefLabel xml:lang="et">lzip</skos:prefLabel>
      <skos:prefLabel xml:lang="en">lzip</skos:prefLabel>
      <skos:definition xml:lang="en">Compressed file produced by lzip, free, command-line tool for the compression of data that employs the Lempel-Ziv-Markov chain algorithm (LZMA).</skos:definition>
