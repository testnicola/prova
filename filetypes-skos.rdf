            <at:legacy-code>application/pdf;type=pdfx</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">PDF printing format, Blind eXchange</skos:altLabel>
      <skos:historyNote xml:lang="en">ISO 15930</skos:historyNote>
      <skos:historyNote xml:lang="en">PDF/X is also called "print optimised".</skos:historyNote>
   </skos:Concept>
