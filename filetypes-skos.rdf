         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">ESRI Arc/Info interchange file</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:historyNote xml:lang="en">{comment_about_IANA} Not present on IANA website</skos:historyNote>
      <skos:historyNote xml:lang="en">Also kown as "Arc/Info Coverage Export File"</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/7Z"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-7z-compressed</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.7z</skos:notation>
      <skos:prefLabel xml:lang="en">7z</skos:prefLabel>
      <skos:prefLabel xml:lang="et">7z</skos:prefLabel>
      <skos:definition xml:lang="en">7z is a compressed archive file format that supports several different data compression, encryption and pre-processing algorithms.</skos:definition>
