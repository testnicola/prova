      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-7z-compressed</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.lpk</skos:notation>
      <skos:prefLabel xml:lang="en">Layer package</skos:prefLabel>
      <skos:prefLabel xml:lang="et">Layer package</skos:prefLabel>
      <skos:definition xml:lang="en">A layer package packages one or more layers and all referenced data sources to create a single compressed .lpk file.</skos:definition>
      <dc:identifier>LPK</dc:identifier>
      <atold:op-code>LPK</atold:op-code>
