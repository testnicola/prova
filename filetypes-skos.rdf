   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/ARJ"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-arj</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.arj</skos:notation>
      <skos:prefLabel xml:lang="en">ARJ</skos:prefLabel>
      <skos:prefLabel xml:lang="et">ARJ</skos:prefLabel>
      <skos:definition xml:lang="en">Compressed archive file produced by ARJ software. ARJ (Archived by Robert Jung) is a software tool designed by Robert K. Jung for creating high-efficiency compressed file archives.</skos:definition>
