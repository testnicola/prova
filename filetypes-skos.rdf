      <skos:prefLabel xml:lang="en">NetCDF</skos:prefLabel>
      <skos:prefLabel xml:lang="et">NetCDF</skos:prefLabel>
      <skos:definition xml:lang="en">NetCDF is a set of software libraries and self-describing, machine-independent data formats that support the creation, access and sharing of array-oriented scientific data.</skos:definition>
