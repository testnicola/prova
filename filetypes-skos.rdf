      <skos:prefLabel xml:lang="en">DXF</skos:prefLabel>
      <skos:prefLabel xml:lang="et">DXF</skos:prefLabel>
      <skos:definition xml:lang="en">A DXF file is a data file saved in a format developed by Autodesk and used for CAD (computer-aided design) vector image files, such as AutoCAD documents. DXF files are similar to .DWG files, but are more compatible with other programs since they are ASCII (text) based.</skos:definition>
      <dc:identifier>DXF</dc:identifier>
      <atold:op-code>DXF</atold:op-code>
      <at:op-code>DXF</at:op-code>
      <at:start.use>1982-01-01</at:start.use>
      <at:authority-code>DXF</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.dxf</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Drawing Interchange Format</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/WFS_SRVC"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">text/xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/gml+xml</skos:notation>
      <skos:prefLabel xml:lang="et">WFS</skos:prefLabel>
      <skos:prefLabel xml:lang="en">WFS</skos:prefLabel>
      <skos:definition xml:lang="en">The Open Geospatial Consortium Web Feature Service (WFS) Interface Standard provides an interface allowing requests for geospatial features across the web using platform-independent mechanisms and is independent of the underlying data store.</skos:definition>
      <dc:identifier>WFS_SRVC</dc:identifier>
      <atold:op-code>WFS_SRVC</atold:op-code>
      <at:op-code>WFS_SRVC</at:op-code>
      <at:start.use>2006-01-01</at:start.use>
      <at:authority-code>WFS_SRVC</at:authority-code>
      <skos:altLabel xml:lang="en">Web Feature Service</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/ISO_ZIP"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/zip</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.zip</skos:notation>
      <skos:prefLabel xml:lang="en">Zipped ISO image</skos:prefLabel>
      <skos:prefLabel xml:lang="et">Tihendatud ISO pilt</skos:prefLabel>
      <skos:definition xml:lang="en">ZIP archive containing an ISO disc image file.</skos:definition>
      <dc:identifier>ISO_ZIP</dc:identifier>
      <atold:op-code>ISO_ZIP</atold:op-code>
      <at:op-code>ISO_ZIP</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>ISO_ZIP</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.zip</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Zipped ISO Disc Image file</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/TAR_XZ"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-compressed</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.tar.xz</skos:notation>
      <skos:prefLabel xml:lang="et">TAR XZ</skos:prefLabel>
      <skos:prefLabel xml:lang="en">TAR XZ</skos:prefLabel>
      <skos:definition xml:lang="en">TAR – tape archive – is a computer software utility for collecting many files into one archive file, often referred to as a tarball, for distribution or backup purposes. XZ is a lossless compression program and file format.</skos:definition>
      <dc:identifier>TAR_XZ</dc:identifier>
      <atold:op-code>TAR_XZ</atold:op-code>
      <at:op-code>TAR_XZ</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>TAR_XZ</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.tar.xz</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">XZ Compressed Tar Archive</skos:altLabel>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} File created using Tar archive and XZ compression tools; contains a .TAR archive that has been compressed using .XZ compression, which compresses at a high ratio. TAR.XZ files are more commonly seen as .TXZ files.</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/MOV"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.mov</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">video/quicktime</skos:notation>
      <skos:prefLabel xml:lang="en">MOV</skos:prefLabel>
      <skos:prefLabel xml:lang="et">MOV</skos:prefLabel>
      <skos:definition xml:lang="en">computer file format used natively by the QuickTime framework; the format specifies a multimedia container file that contains one or more tracks, each of which stores a particular type of data: audio, video, or text (e.g. for subtitles)</skos:definition>
      <dc:identifier>MOV</dc:identifier>
      <atold:op-code>MOV</atold:op-code>
      <at:op-code>MOV</at:op-code>
      <at:start.use>2001-03-01</at:start.use>
      <at:authority-code>MOV</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.mov</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">QuickTime Movie</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/EAR"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.ear</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/java-archive</skos:notation>
      <skos:prefLabel xml:lang="et">EAR</skos:prefLabel>
      <skos:prefLabel xml:lang="en">EAR</skos:prefLabel>
      <skos:definition xml:lang="en">EAR (Enterprise Application aRchive) is a file format used by Java EE for packaging one or more modules into a single archive.</skos:definition>
      <dc:identifier>EAR</dc:identifier>
      <atold:op-code>EAR</atold:op-code>
      <at:op-code>EAR</at:op-code>
      <at:start.use>2006-05-11</at:start.use>
      <at:authority-code>EAR</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.ear</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Enterprise Application Archive</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/ODS"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.ods</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/vnd.oasis.opendocument.spreadsheet</skos:notation>
      <skos:prefLabel xml:lang="et">ODS</skos:prefLabel>
      <skos:prefLabel xml:lang="en">ODS</skos:prefLabel>
      <skos:definition xml:lang="en">ODS is an OpenDocument file format for spreadsheets. OpenDocument was developed with the aim of providing an open, XML-based file format specification for office applications.</skos:definition>
      <dc:identifier>ODS</dc:identifier>
      <atold:op-code>ODS</atold:op-code>
      <at:op-code>ODS</at:op-code>
      <at:start.use>2013-11-27</at:start.use>
      <at:authority-code>ODS</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.ods</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-machine-readable</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-nonPropExt</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">OpenDocument Spreadsheet</skos:altLabel>
      <skos:changeNote xml:lang="en">DCAT proposal 2013-11-27</skos:changeNote>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} Spreadsheet created by the Calc program included with StarOffice or the open-source office suite, Apache OpenOffice; stores data in cells that are organized into rows and columns; formatted using the OASIS OpenDocument XML-based standard. NOTE: Apache OpenOffice was previously known as OpenOffice.org</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/MATHML"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/mathml-presentation+xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.mml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/mathml-content+xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/mathml+xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.mathml</skos:notation>
      <skos:prefLabel xml:lang="et">MathML</skos:prefLabel>
      <skos:prefLabel xml:lang="en">MathML</skos:prefLabel>
      <skos:definition xml:lang="en">mathematical markup language, an application of XML for describing mathematical notations and capturing both its structure and content</skos:definition>
      <dc:identifier>MATHML</dc:identifier>
      <atold:op-code>MATHML</atold:op-code>
      <at:op-code>MATHML</at:op-code>
      <at:start.use>1998-04-01</at:start.use>
      <at:authority-code>MATHML</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.mml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.mathml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Mathematical Markup Language</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/RDF_THRIFT"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.trdf</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.rt</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/rdf+thrift</skos:notation>
      <skos:prefLabel xml:lang="en">RDF Thrift</skos:prefLabel>
      <skos:prefLabel xml:lang="et">RDF Thrift</skos:prefLabel>
      <skos:definition xml:lang="en">RDF Binary using Apache Thrift (‘RDF Thrift’) is a binary format for RDF and RDF-related data. Binary formats are faster to process – they do not incur the parsing costs of text-base formats. RDF Thrift defines basic encoding for RDF terms, then builds data formats for RDF graphs, RDF datasets and for SPARQL result sets. This gives a basis for high-performance linked data systems.</skos:definition>
      <dc:identifier>RDF_THRIFT</dc:identifier>
      <atold:op-code>RDF_THRIFT</atold:op-code>
      <at:op-code>RDF_THRIFT</at:op-code>
      <at:start.use>2014-01-01</at:start.use>
      <at:authority-code>RDF_THRIFT</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.rt</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.trdf</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">RDF Binary Thrift</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/MHTML"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">message/html</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.mhtml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.mht</skos:notation>
      <skos:prefLabel xml:lang="en">MHTML</skos:prefLabel>
      <skos:prefLabel xml:lang="et">MHTML</skos:prefLabel>
      <skos:definition xml:lang="en">MHTML – MIME Encapsulation of Aggregate HTML Documents – is a web page archive format used to combine in a single document the HTML code and its companion resources that are otherwise represented by external links (such as images, Flash animations, Java applets and audio files). The content of an MHTML file is encoded as if it were an HTML e-mail message.</skos:definition>
      <dc:identifier>MHTML</dc:identifier>
      <atold:op-code>MHTML</atold:op-code>
      <at:op-code>MHTML</at:op-code>
      <at:start.use>1999-03-01</at:start.use>
      <at:authority-code>MHTML</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.mhtml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.mht</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">MIME HTML</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/FMX4_ZIP"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/zip</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.zip</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/zip;type=fmx4</skos:notation>
      <skos:prefLabel xml:lang="et">FMX4 ZIP</skos:prefLabel>
      <skos:prefLabel xml:lang="en">FMX4 ZIP</skos:prefLabel>
      <skos:definition xml:lang="en">FMX4 ZIP is a ZIP archive containing files that all belong to a Formex 4 instance.</skos:definition>
      <dc:identifier>FMX4_ZIP</dc:identifier>
      <atold:op-code>FMX4_ZIP</atold:op-code>
      <at:op-code>FMX4_ZIP</at:op-code>
