      <skos:prefLabel xml:lang="en">Atom Feed</skos:prefLabel>
      <skos:prefLabel xml:lang="et">Atom voog</skos:prefLabel>
      <skos:definition xml:lang="en">The Atom Feed or Atom Syndication Format is an XML language used for web feeds. Web feeds allow software programs to check for updates published on a website.</skos:definition>
