      <skos:prefLabel xml:lang="en">JavaScript</skos:prefLabel>
      <skos:prefLabel xml:lang="et">JavaScript</skos:prefLabel>
      <skos:definition xml:lang="en">JavaScript is a high-level, interpreted programming language. It is a language which is also characterized as dynamic, weakly typed, prototype-based and multi-paradigm.</skos:definition>
