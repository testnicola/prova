   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/FMX3"
                 at:deprecated="true">
      <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
      <euvoc:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1750</euvoc:order>
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
