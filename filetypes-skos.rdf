   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/JPEG"
                 at:deprecated="false">
      <euvoc:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1700</euvoc:order>
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">image/jpeg</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.jpeg</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.jpg</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">image/jpeg</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MANIFT">jepg</skos:notation>
      <skos:prefLabel xml:lang="en">JPEG</skos:prefLabel>
      <skos:prefLabel xml:lang="et">JPEG</skos:prefLabel>
      <skos:definition xml:lang="en">JPEG – Joint Photographic Experts Group – is a commonly used method of lossy compression for digital images, particularly for those images produced by digital photography. The degree of compression can be adjusted, allowing a selectable tradeoff between storage size and image quality.</skos:definition>
      <dc:identifier>JPEG</dc:identifier>
      <atold:op-code>JPEG</atold:op-code>
      <at:op-code>JPEG</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
