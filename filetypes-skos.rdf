      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.ics</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.ifb</skos:notation>
