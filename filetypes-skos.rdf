         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">lzip compressed file</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/OCTET"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/octet-stream</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/octet-stream</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.zoo</skos:notation>
      <skos:prefLabel xml:lang="en">Octet Stream</skos:prefLabel>
      <skos:prefLabel xml:lang="et">Octet voog</skos:prefLabel>
      <skos:definition xml:lang="en">Octet is the Internet media type for an arbitrary byte stream. A byte streamor octet stream is a series of bytes.</skos:definition>
      <dc:identifier>OCTET</dc:identifier>
      <atold:op-code>OCTET</atold:op-code>
      <at:op-code>OCTET</at:op-code>
