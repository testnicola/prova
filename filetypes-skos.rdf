      <skos:prefLabel xml:lang="en">Formex 4</skos:prefLabel>
      <skos:prefLabel xml:lang="et">Formex 4</skos:prefLabel>
      <skos:definition xml:lang="en">Formex describes the format for the exchange of data between the Publication Office and its contractors. In particular, it defines the logical markup for documents which are published in the different series of the Offical Journal of the European Union. Formex V4 is based on the international standard XML.</skos:definition>
      <dc:identifier>FMX4</dc:identifier>
      <atold:op-code>FMX4</atold:op-code>
      <at:op-code>FMX4</at:op-code>
      <at:start.use>2004-05-01</at:start.use>
      <at:authority-code>FMX4</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>manifestation-type-cellar</dc:source>
            <at:legacy-code>fmx4</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>priority-weight-cellar</dc:source>
            <at:legacy-code>1800</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.xml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/xml;type=fmx4</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-textual-cellar</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Formalized Exchange of Electronic Publications (Formex), version 4</skos:altLabel>
      <skos:historyNote xml:lang="en">Formex 4 1.5.2004 - : Structure language created and maintained by the Publications Office, on the basis of XML and Unicode as characterset.</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/RTF"
                 at:deprecated="false">
