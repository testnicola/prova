         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.war</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Web Archive</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/OAPK"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
