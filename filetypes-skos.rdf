         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">MOPAC Input Format</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
