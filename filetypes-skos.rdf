         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.mpeg</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>mpg</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
