   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/E00"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-e00</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.e00</skos:notation>
      <skos:prefLabel xml:lang="et">E00</skos:prefLabel>
      <skos:prefLabel xml:lang="en">E00</skos:prefLabel>
      <skos:definition xml:lang="en">E00 is an ArcInfo interchange file format. ArcInfo is a full-featured geographic information system produced by Esri.</skos:definition>
      <dc:identifier>E00</dc:identifier>
      <atold:op-code>E00</atold:op-code>
