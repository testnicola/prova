      <skos:prefLabel xml:lang="et">CSV</skos:prefLabel>
      <skos:prefLabel xml:lang="en">CSV</skos:prefLabel>
      <skos:definition xml:lang="en">CSV – comma-separated values – files store tabular data (numbers and text) in plain text. Each line of the file is a data record. Each record consists of one or more fields, separated by commas.</skos:definition>
      <dc:identifier>CSV</dc:identifier>
      <atold:op-code>CSV</atold:op-code>
