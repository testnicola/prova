   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/RDF_TURTLE"
                 at:deprecated="false">
      <euvoc:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1190</euvoc:order>
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">text/turtle</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MANIFT">rdf_turtle</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.ttl</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">text/turtle</skos:notation>
      <skos:prefLabel xml:lang="et">RDF Turtle</skos:prefLabel>
      <skos:prefLabel xml:lang="en">RDF Turtle</skos:prefLabel>
      <skos:definition xml:lang="en">Turtle – Terse RDF Triple Language – is a format for expressing data in the Resource Description Framework (RDF) data model with a syntax similar to SPARQL. RDF, in turn, represents information using ‘triples’, each of which consists of a subject, a predicate and an object. Each of those items is expressed as a Web URI.</skos:definition>
      <dc:identifier>RDF_TURTLE</dc:identifier>
      <atold:op-code>RDF_TURTLE</atold:op-code>
      <at:op-code>RDF_TURTLE</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>RDF_TURTLE</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-machine-readable</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>priority-weight-cellar</dc:source>
            <at:legacy-code>1190</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-nonPropExt</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-textual-cellar</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>manifestation-type-cellar</dc:source>
            <at:legacy-code>rdf_turtle</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>text/turtle</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.ttl</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Terse RDF Triple Language</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} RDF_TURTLE put to show why RDF_XML has an underscore-extension.</skos:historyNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/GEOJSON"
