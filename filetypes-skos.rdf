            <at:legacy-code>.rev</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Roshal Archive</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/WORLD"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.jgw</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-worldfile</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.tfw</skos:notation>
      <skos:prefLabel xml:lang="en">World file</skos:prefLabel>
      <skos:prefLabel xml:lang="et">World file</skos:prefLabel>
      <skos:definition xml:lang="en">A world file is a plain text computer data file used by geographic information systems (GIS) to georeference raster map images. The file extension usually depends on the format of the associated image, e.g. .jgw for JPEG (2000) or .tfw for TIFF.</skos:definition>
      <dc:identifier>WORLD</dc:identifier>
      <atold:op-code>WORLD</atold:op-code>
      <at:op-code>WORLD</at:op-code>
      <at:start.use>2001-03-26</at:start.use>
      <at:authority-code>WORLD</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.jgw</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.tfw</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/REST"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">arcgis_rest</skos:notation>
      <skos:prefLabel xml:lang="en">Esri REST</skos:prefLabel>
      <skos:prefLabel xml:lang="et">Esri REST</skos:prefLabel>
      <skos:definition xml:lang="en">Esri REST is a standard way for web clients to communicate with geographic information system (GIS) servers through Representational State Transfer (REST) technology.</skos:definition>
      <dc:identifier>REST</dc:identifier>
      <atold:op-code>REST</atold:op-code>
      <at:op-code>REST</at:op-code>
      <at:start.use>2010-01-01</at:start.use>
      <at:authority-code>REST</at:authority-code>
      <skos:altLabel xml:lang="en">Esri Representational State Transfer</skos:altLabel>
      <skos:changeNote xml:lang="en">* Documentation: http://www.esri.com/library/whitepapers/pdfs/geoservices-rest-spec.pdf</skos:changeNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/TMX"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/xml</skos:notation>
      <skos:prefLabel xml:lang="et">TMX</skos:prefLabel>
      <skos:prefLabel xml:lang="en">TMX</skos:prefLabel>
      <skos:definition xml:lang="en">TMX – Translation Memory eXchange – is an XML specification for the exchange of translation memory data between computer-aided translation and localization tools with little or no loss of critical data.</skos:definition>
      <dc:identifier>TMX</dc:identifier>
      <atold:op-code>TMX</atold:op-code>
      <at:op-code>TMX</at:op-code>
      <at:start.use>1997-11-25</at:start.use>
      <at:authority-code>TMX</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.xml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/xml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Translation Memory eXchange</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/SB3"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.sb3</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.sprite3</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-sb3</skos:notation>
      <skos:prefLabel xml:lang="et">sb3</skos:prefLabel>
      <skos:prefLabel xml:lang="en">sb3</skos:prefLabel>
      <skos:definition xml:lang="en">Scratch 3.0 is a file format used to store exported Scratch 3.0 projects and sprites. These are ZIP archives which contain information encoded in a text-based JSON format and project media in separate files.</skos:definition>
      <dc:identifier>SB3</dc:identifier>
      <atold:op-code>SB3</atold:op-code>
      <at:op-code>SB3</at:op-code>
      <at:start.use>2019-01-02</at:start.use>
      <at:authority-code>SB3</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.sb3</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.sprite3</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Scratch 3.0</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/RDF_N_QUADS"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/n-quads</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.nq</skos:notation>
      <skos:prefLabel xml:lang="en">RDF N-Quads</skos:prefLabel>
      <skos:prefLabel xml:lang="et">RDF N-Quads</skos:prefLabel>
      <skos:definition xml:lang="en">N-Quads is a line-based, plain text format for encoding an RDF dataset. N-quads statements are a sequence of RDF terms representing the subject, predicate, object and graph label of an RDF Triple and the graph it is part of in a dataset.</skos:definition>
      <dc:identifier>RDF_N_QUADS</dc:identifier>
      <atold:op-code>RDF_N_QUADS</atold:op-code>
      <at:op-code>RDF_N_QUADS</at:op-code>
      <at:start.use>2013-04-09</at:start.use>
      <at:authority-code>RDF_N_QUADS</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-machine-readable</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.nq</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-nonPropExt</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Resource Description Framework N-Quads</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/DGN"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/octet-stream</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.dgn</skos:notation>
      <skos:prefLabel xml:lang="en">DGN</skos:prefLabel>
      <skos:prefLabel xml:lang="et">DGN</skos:prefLabel>
      <skos:definition xml:lang="en">A DGN file is a 2D/3D drawing created by various construction CAD software, such as MicroStation and Intergraph Interactive Graphics Design System. It may be saved in one of two formats, either the Intergraph Standard File Format (ISFF) or the newer V8 DGN standard. DGN files are typically used to save designs for construction projects for highways, bridges, and buildings.</skos:definition>
      <dc:identifier>DGN</dc:identifier>
      <atold:op-code>DGN</atold:op-code>
      <at:op-code>DGN</at:op-code>
      <at:start.use>2000-01-01</at:start.use>
      <at:authority-code>DGN</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.dgn</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">DGN file</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/WEBP"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">image/webp</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.webp</skos:notation>
      <skos:prefLabel xml:lang="en">WebP</skos:prefLabel>
      <skos:prefLabel xml:lang="et">WebP</skos:prefLabel>
      <skos:definition xml:lang="en">WebP is an image file format developed by Google intended as a replacement for JPEG, PNG, and GIF file formats. It supports both lossy and lossless compression, as well as animation and alpha transparency.</skos:definition>
      <dc:identifier>WEBP</dc:identifier>
      <atold:op-code>WEBP</atold:op-code>
      <at:op-code>WEBP</at:op-code>
      <at:start.use>2010-09-30</at:start.use>
      <at:authority-code>WEBP</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.webp</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">WebP image</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/WCS_SRVC"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">text/xml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">multipart/related</skos:notation>
      <skos:prefLabel xml:lang="en">WCS</skos:prefLabel>
      <skos:prefLabel xml:lang="et">WCS</skos:prefLabel>
      <skos:definition xml:lang="en">The Open Geospatial Consortium Web Coverage Service Interface Standard (WCS) defines Web-based retrieval of coverages – that is, digital geospatial information representing space/time-varying phenomena.</skos:definition>
      <dc:identifier>WCS_SRVC</dc:identifier>
      <atold:op-code>WCS_SRVC</atold:op-code>
      <at:op-code>WCS_SRVC</at:op-code>
      <at:start.use>2003-08-27</at:start.use>
      <at:authority-code>WCS_SRVC</at:authority-code>
      <skos:altLabel xml:lang="en">Web Coverage Service</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/TAR"
                 at:deprecated="false">
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.tar</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/x-tar</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/x-tar</skos:notation>
      <skos:prefLabel xml:lang="en">TAR</skos:prefLabel>
      <skos:prefLabel xml:lang="et">TAR</skos:prefLabel>
      <skos:definition xml:lang="en">TAR – tape archive – is a computer software utility for collecting many files into one archive file for distribution or backup purposes.</skos:definition>
      <dc:identifier>TAR</dc:identifier>
      <atold:op-code>TAR</atold:op-code>
      <at:op-code>TAR</at:op-code>
      <at:start.use>2012-09-01</at:start.use>
      <at:authority-code>TAR</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.tar</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-nonPropExt</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/x-tar</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Tape Archive</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
      <skos:historyNote xml:lang="en">{comment_about_IANA} Not present on IANA website</skos:historyNote>
      <skos:historyNote xml:lang="en">{op_comment_eng_private} Tar archive created by tar, a Unix-based utility used to package files together; contains multiple files stored in an uncompressed format; commonly compressed into a .GZ file using GNU Zip compression.</skos:historyNote>
   </skos:Concept>
