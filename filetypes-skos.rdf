      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/xml;type=fmx3</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">text/sgml</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">text/sgml;type=fmx3</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.xml</skos:notation>
      <skos:prefLabel xml:lang="et">Formex 3</skos:prefLabel>
      <skos:prefLabel xml:lang="en">Formex 3</skos:prefLabel>
      <skos:definition xml:lang="en">Formex describes the format for the exchange of data between the Publication Office and its contractors. In particular, it defines the logical markup for documents which are published in the different series of the Offical Journal of the European Union. Formex 3 was a previous version of Formex actually used.</skos:definition>
      <dc:identifier>FMX3</dc:identifier>
      <atold:op-code>FMX3</atold:op-code>
      <at:op-code>FMX3</at:op-code>
      <at:start.use>1999-04-01</at:start.use>
      <at:authority-code>FMX3</at:authority-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>application/xml;type=fmx3</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>mime-type-cellar</dc:source>
            <at:legacy-code>text/sgml;type=fmx3</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>file-extension</dc:source>
            <at:legacy-code>.xml</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>is-textual-cellar</dc:source>
            <at:legacy-code>true</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>manifestation-type-cellar</dc:source>
            <at:legacy-code>fmx3</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <at:op-mapped-code>
         <at:MappedCode>
            <dc:source>priority-weight-cellar</dc:source>
            <at:legacy-code>1750</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Formalized Exchange of Electronic Publications (Formex), version 3</skos:altLabel>
      <skos:historyNote xml:lang="en">Formex 3 1.4.1999 - 30.4.2004: Structure language created and maintained by the Publications Office, on the basis of SGML. The character encoding is organised according to ISO 2022 and ISO 8856-*.</skos:historyNote>
      <skos:historyNote xml:lang="en">{comment_about_IANA} No file extension on IANA website</skos:historyNote>
      <at:end.use>2004-04-30</at:end.use>
   </skos:Concept>
