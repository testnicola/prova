            <dc:source>priority-weight-cellar</dc:source>
            <at:legacy-code>3000</at:legacy-code>
         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">Text file</skos:altLabel>
      <skos:changeNote xml:lang="en">ODP proposal 2013-09-16</skos:changeNote>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/PDFA1B"
                 at:deprecated="false">
      <euvoc:order rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2600</euvoc:order>
      <skos:inScheme rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:topConceptOf rdf:resource="http://publications.europa.eu/resource/authority/file-type"/>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">application/pdf</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.pdf</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MANIFT">pdfa1b</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MT">application/pdf;type=pdfa1b</skos:notation>
      <skos:prefLabel xml:lang="en">PDF/A-1b</skos:prefLabel>
      <skos:prefLabel xml:lang="et">PDF/A-1b</skos:prefLabel>
      <skos:definition xml:lang="en">PDF/A-1 is the Part 1 of the PDF standard and specifies two levels of conformance for PDF files. Level B (basic) conformance requires only that standards necessary for the reliable reproduction of a document's visual appearance be followed.</skos:definition>
      <dc:identifier>PDFA1B</dc:identifier>
      <atold:op-code>PDFA1B</atold:op-code>
      <at:op-code>PDFA1B</at:op-code>
