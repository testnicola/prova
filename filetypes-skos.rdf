      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#CELLAR_MANIFT">rtf</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#IANA_MT">text/rtf</skos:notation>
      <skos:notation rdf:datatype="http://publications.europa.eu/ontology/euvoc#FILE_EXT">.rtf</skos:notation>
      <skos:prefLabel xml:lang="en">RTF</skos:prefLabel>
      <skos:prefLabel xml:lang="et">RTF</skos:prefLabel>
      <skos:definition xml:lang="en">RTF – Rich Text Format – is a proprietary document file format developed for cross-platform document interchange with Microsoft products.</skos:definition>
      <dc:identifier>RTF</dc:identifier>
      <atold:op-code>RTF</atold:op-code>
      <at:op-code>RTF</at:op-code>
