         </at:MappedCode>
      </at:op-mapped-code>
      <skos:altLabel xml:lang="en">SPARQL Query</skos:altLabel>
   </skos:Concept>
   <skos:Concept rdf:about="http://publications.europa.eu/resource/authority/file-type/EPUB"
                 at:deprecated="false">
